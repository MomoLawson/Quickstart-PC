{
  "cursor": {
    "name": "Cursor",
    "desc": "AI 代码编辑器/AI code editor",
    "win": "winget install Anysphere.Cursor",
    "mac": "brew install --cask cursor",
    "linux": "curl -o /tmp/cursor.AppImage https://cursor.sh/linux/x64 && chmod +x /tmp/cursor.AppImage",
    "linux_dnf": "curl -o /tmp/cursor.AppImage https://cursor.sh/linux/x64 && chmod +x /tmp/cursor.AppImage",
    "linux_pacman": "yay -S cursor",
    "check_win": "winget list Anysphere.Cursor",
    "check_mac": "ls /Applications/Cursor.app 2>/dev/null",
    "check_linux": "which cursor 2>/dev/null",
    "check_linux_dnf": "which cursor 2>/dev/null",
    "check_linux_pacman": "which cursor 2>/dev/null",
    "tier": "stable"
  },
  "ollama": {
    "name": "Ollama",
    "desc": "本地 LLM/Local LLM runner",
    "win": "powershell -Command \"irm https://ollama.ai/install.ps1 | iex\"",
    "mac": "brew install ollama",
    "linux": "curl -fsSL https://ollama.ai/install.sh | sh",
    "linux_dnf": "curl -fsSL https://ollama.ai/install.sh | sh",
    "linux_pacman": "sudo pacman -S ollama",
    "check_win": "winget list Ollama.Ollama",
    "check_mac": "which ollama 2>/dev/null",
    "check_linux": "which ollama 2>/dev/null",
    "check_linux_dnf": "which ollama 2>/dev/null",
    "check_linux_pacman": "which ollama 2>/dev/null",
    "tier": "stable"
  },
  "lmstudio": {
    "name": "LM Studio",
    "desc": "本地 LLM 客户端/Local LLM client",
    "win": "winget install LMStudio.LMStudio",
    "mac": "curl -L \"https://install.lmstudio.ai/mac\" -o /tmp/LMStudio.dmg && hdiutil attach /tmp/LMStudio.dmg && cp -R /Volumes/LM\\ Studio/LM\\ Studio.app /Applications/ && hdiutil detach /Volumes/LM\\ Studio",
    "linux": "curl -L \"https://install.lmstudio.ai/linux\" -o /tmp/lm-studio.AppImage && chmod +x /tmp/lm-studio.AppImage && mv /tmp/lm-studio.AppImage ~/lm-studio.AppImage",
    "linux_dnf": "curl -L \"https://install.lmstudio.ai/linux\" -o /tmp/lm-studio.AppImage && chmod +x /tmp/lm-studio.AppImage && mv /tmp/lm-studio.AppImage ~/lm-studio.AppImage",
    "linux_pacman": "yay -S lm-studio",
    "check_win": "winget list LMStudio.LMStudio",
    "check_mac": "ls /Applications/LM\\ Studio.app 2>/dev/null",
    "check_linux": "test -f ~/lm-studio.AppImage && echo installed",
    "check_linux_dnf": "test -f ~/lm-studio.AppImage && echo installed",
    "check_linux_pacman": "which lm-studio 2>/dev/null",
    "tier": "stable"
  },
