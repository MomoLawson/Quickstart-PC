{
  "dbeaver": {
    "name": "DBeaver",
    "desc": "数据库管理工具/Database management tool",
    "win": "winget install DBeaver.DBeaver",
    "mac": "brew install --cask dbeaver-community",
    "linux": "sudo apt install -y dbeaver-ce",
    "linux_dnf": "sudo dnf install -y dbeaver",
    "linux_pacman": "yay -S dbeaver",
    "check_win": "winget list DBeaver.DBeaver",
    "check_mac": "ls /Applications/DBeaver.app 2>/dev/null",
    "check_linux": "which dbeaver 2>/dev/null",
    "check_linux_dnf": "which dbeaver 2>/dev/null",
    "check_linux_pacman": "which dbeaver 2>/dev/null",
    "tier": "stable"
  },
  "tableplus": {
