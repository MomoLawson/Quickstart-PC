{
  "balenaetcher": {
    "name": "BalenaEtcher",
    "desc": "镜像烧录工具/Image flashing tool",
    "win": "winget install Balena.Etcher",
    "mac": "brew install --cask balenaetcher",
    "linux": "curl -L \"https://github.com/balena-io/etcher/releases/latest/download/balenaEtcher-x64.AppImage\" -o /tmp/balena-etcher.AppImage && chmod +x /tmp/balena-etcher.AppImage",
    "linux_dnf": "curl -L \"https://github.com/balena-io/etcher/releases/latest/download/balenaEtcher-x64.AppImage\" -o /tmp/balena-etcher.AppImage && chmod +x /tmp/balena-etcher.AppImage",
    "linux_pacman": "yay -S balena-etcher",
    "check_win": "winget list Balena.Etcher",
    "check_mac": "ls /Applications/balenaEtcher.app 2>/dev/null",
    "check_linux": "which balena-etcher 2>/dev/null",
    "check_linux_dnf": "which balena-etcher 2>/dev/null",
    "check_linux_pacman": "which balena-etcher 2>/dev/null",
    "tier": "stable"
  },
