{
  "telegram": {
    "name": "Telegram",
    "desc": "即时通讯/Instant messaging",
    "win": "winget install Telegram.TelegramDesktop",
    "mac": "brew install --cask telegram",
    "linux": "sudo apt install -y telegram-desktop",
    "linux_dnf": "sudo dnf install -y telegram-desktop",
    "linux_pacman": "sudo pacman -S telegram-desktop",
    "check_win": "winget list Telegram.TelegramDesktop",
    "check_mac": "ls /Applications/Telegram.app 2>/dev/null",
    "check_linux": "which telegram-desktop 2>/dev/null",
    "check_linux_dnf": "which telegram-desktop 2>/dev/null",
    "check_linux_pacman": "which telegram-desktop 2>/dev/null",
    "tier": "stable"
  },
